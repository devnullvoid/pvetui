Set Width 1400
Set Height 800
Set Padding 10
Set Theme "Catppuccin Mocha"
Set FontFamily "Monaspace Krypton"
Set TypingSpeed 100ms
Set Shell "bash"

Hide
Type@50ms "env -u NO_COLOR TERM=xterm-256color COLORTERM=truecolor ./bin/pvetui --config $PVETUI_MEDIA_CONFIG --profile $PVETUI_MEDIA_PROFILE --no-cache"
Enter
Show
